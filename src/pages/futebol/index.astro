---
import MainLayout from '../../layouts/MainLayout.astro';
import PostCard from '../../components/PostCard.astro';

const posts = await Astro.glob('./*.astro');
const categoryPosts = posts
    .filter(post => {
        // Ignora a própria página de índice
        if (post.url === '/futebol' || post.url === '/futebol/') return false;
        // Verifica se tem título e url (o Astro.glob retorna objetos mesmo para arquivos sem export)
        return post.title && post.url;
    })
    .sort((a, b) => new Date(b.date || '0').getTime() - new Date(a.date || '0').getTime());

const categoria = "futebol";
const title = "Futebol";
const description = "Confira as últimas notícias, análises e onde assistir aos jogos de futebol.";
---

<MainLayout title={title} description={description} categoria={categoria} showRelacionados={false}>
    <h1 class="page-title" style="margin-bottom: 2rem; color: #2563eb;">{title}</h1>
    
    <div class="posts-grid">
        {categoryPosts.map(post => (
            <PostCard 
                title={post.title}
                description={post.description}
                url={post.url}
                image={post.image || '/images/default-post.webp'}
                date={post.date}
            />
        ))}
    </div>
</MainLayout>
