---
import MainLayout from '../layouts/MainLayout.astro';

export const title = "código de convite kwai atualizado 2024: Kwai124418658";
export const description = "Se você está procurando um código de convite para adicionar no Kwai, você está no lugar certo.";
export const categoria = "GANHAR DINHEIRO";
export const date = "2025-04-21";
export const image = "/images/adicione-o-codigo-para-ganhar-dinheiro.avif";
---

<MainLayout title={title} description={description} categoria={categoria}>
    <article class="post-full">
        <h1>{title}</h1>
        <time class="post-date">Atualizado 21 de Abril de 2025</time>
        
        <img src="/images/adicione-o-codigo-para-ganhar-dinheiro.avif" alt="adicione o codigo de convite para ganhar dinheiro" style="display: block; margin: 0 auto;" />
        
        <div class="post-content-full">
            <p>
                código de convite kwai atualizado 2024: <strong>Kwai124418658</strong>
                Se você está procurando um código de convite para adicionar no Kwai, você está no lugar certo.
                código de convite kwai atualizado 2024: Kwai124418658
                Ganhe mais dinheiro usando o código de convite kwai. Kwai124418658 é o código do convite</p>
            
            <div class="code-container" style="text-align: center; margin: 1rem auto; max-width: 300px; background: #f3f4f6; padding: 1rem; border-radius: 8px;">
                <div class="code" id="codigo-kwai" style="font-size: 1.5rem; font-weight: bold; margin-bottom: 0.5rem;">Kwai124418658</div>
                <button class="btn-copy" id="copy-btn-kwai" style="background: #2563eb; color: white; border: none; padding: 0.5rem 1rem; border-radius: 4px; cursor: pointer;">Copiar</button>
            </div>

            <div class="button-container" style="margin: 2rem 0;">
                <a href="https://kwai-video.com/f/kKIdh0ou" target="_blank" rel="noopener noreferrer" class="action-button">Baixar App Kwai</a>
            </div>
        </div>
    </article>

    <style>
        .button-container {
            display: flex;
            justify-content: center;
            gap: 1rem;
            flex-wrap: wrap;
            margin: 2rem auto;
        }
        .action-button {
            padding: 0.75rem 1.5rem;
            background-color: #2563eb;
            color: white;
            border: none;
            border-radius: 4px;
            cursor: pointer;
            font-size: 1rem;
            text-decoration: none;
            display: inline-block;
            transition: background-color 0.3s;
        }
    </style>

    <script is:inline>
        const copyBtnKwai = document.getElementById('copy-btn-kwai');
        if (copyBtnKwai) {
            copyBtnKwai.addEventListener('click', () => {
                const code = document.getElementById('codigo-kwai').textContent;
                navigator.clipboard.writeText(code).then(() => {
                    const originalText = copyBtnKwai.textContent;
                    copyBtnKwai.textContent = 'Copiado!';
                    copyBtnKwai.classList.add('success');
                    setTimeout(() => {
                        copyBtnKwai.textContent = originalText;
                        copyBtnKwai.classList.remove('success');
                    }, 2000);
                });
            });
        }
    </script>
</MainLayout>
