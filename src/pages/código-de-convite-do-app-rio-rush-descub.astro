---
import MainLayout from '../layouts/MainLayout.astro';

export const title = "Código de Convite Rio Rush Descubra Nova Vida - Onde Colocar";
export const description = "use o codigo de convite 00WKIX no aplicativo rio rush e comece ganhar dinheiro hoje mesmo";
export const categoria = "GANHAR DINHEIRO";
export const date = "2025-01-01";
export const image = "/images/rio-rush.webp";
---

<MainLayout title={title} description={description} categoria={categoria}>
    <article class="post-full">
        <h1>{title}</h1>
        
        <img src="/images/rio-rush.webp" alt="logo rio rush" style="display: block; margin: 0 auto; margin-bottom: 2%;" />
        <div style="text-align: center; margin-bottom: 2rem;">
            <a href="https://youtu.be/7De8iLyp65k" target="_blank">Assista tutorial no YouTube</a>
        </div>

        <div class="post-content-full">
            <h2>Código de Convite 👉 00WKIX</h2>
            <p> Código de convite para colocar no app rio rush: <strong>00WKIX</strong> 
                código de convite rio rush
                Se você está procurando um <strong>código de convite</strong> para colocar no aplicativo rio rush ou não
                sabe onde colocar você está no vídeo certo nesse vídeo eu vou deixar o código de convite
                e também vou mostrar aonde colocar o código de convite no aplicativo eu rio rush e para quem ainda não tem o aplicativo e também vou estar deixando o link para download abaixo.</p>
            
            <div class="code-container" style="text-align: center; margin: 1rem auto; max-width: 300px; background: #f3f4f6; padding: 1rem; border-radius: 8px;">
                <div class="code" id="rio-rush-codigo" style="font-size: 1.5rem; font-weight: bold; margin-bottom: 0.5rem;">00WKIX</div>
                <button class="btn-copy" id="copy-btn-riorush" style="background: #2563eb; color: white; border: none; padding: 0.5rem 1rem; border-radius: 4px; cursor: pointer;">Copiar</button>
            </div>

            <div class="button-container" style="margin: 2rem 0;">
                <a href="https://mshare.tapfun.pro/invite?u=NzY1ODUz" target="_blank" rel="noopener noreferrer" class="action-button">Baixar App Rio Rush</a>
            </div>
        </div>
    </article>

    <style>
        .button-container {
            display: flex;
            justify-content: center;
            gap: 1rem;
            flex-wrap: wrap;
            margin: 2rem auto;
        }
        .action-button {
            padding: 0.75rem 1.5rem;
            background-color: #2563eb;
            color: white;
            border: none;
            border-radius: 4px;
            cursor: pointer;
            font-size: 1rem;
            text-decoration: none;
            display: inline-block;
            transition: background-color 0.3s;
        }
    </style>

    <script is:inline>
        const copyBtnRiorush = document.getElementById('copy-btn-riorush');
        if (copyBtnRiorush) {
            copyBtnRiorush.addEventListener('click', () => {
                const code = document.getElementById('rio-rush-codigo').textContent;
                navigator.clipboard.writeText(code).then(() => {
                    const originalText = copyBtnRiorush.textContent;
                    copyBtnRiorush.textContent = 'Copiado!';
                    copyBtnRiorush.classList.add('success');
                    setTimeout(() => {
                        copyBtnRiorush.textContent = originalText;
                        copyBtnRiorush.classList.remove('success');
                    }, 2000);
                });
            });
        }
    </script>
</MainLayout>
