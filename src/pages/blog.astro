---
import MainLayout from '../layouts/MainLayout.astro';
import PostCard from '../components/PostCard.astro';

const posts = await Astro.glob('./post/*.astro');
const blogPosts = posts
    .filter(post => {
        const title = post.title || post.frontmatter?.title;
        // Deve ter título, URL e não ser uma página de índice
        return post.url && title && !post.file.endsWith('index.astro');
    })
    .sort((a, b) => {
        const dateA = new Date(a.date || a.frontmatter?.date || '0').getTime();
        const dateB = new Date(b.date || b.frontmatter?.date || '0').getTime();
        return dateB - dateA;
    });

const title = "Blog";
const description = "Blog sobre como lucrar online, dicas e estratégias para ganhar dinheiro na internet";
const categoria = "blog";
---

<MainLayout title={title} description={description} categoria={categoria}>
    <h1 class="page-title" style="margin-bottom: 2rem; color: #2563eb;">Blog</h1>
    
    <div class="posts-grid">
        {blogPosts.map(post => {
            const postTitle = post.title || post.frontmatter?.title;
            const postDescription = post.description || post.frontmatter?.description;
            const postImage = post.image || post.frontmatter?.image || '/images/default-post.webp';
            const postDate = post.date || post.frontmatter?.date;
            
            return (
                <PostCard 
                    title={postTitle}
                    description={postDescription}
                    url={post.url}
                    image={postImage}
                    date={postDate}
                />
            );
        })}
    </div>

    <nav aria-label="breadcrumb" style="margin-top: 2rem;">
        <ol class="breadcrumb" style="display: flex; list-style: none; gap: 0.5rem; padding: 0; color: #6b7280; font-size: 0.875rem;">
            <li><a href="/" style="color: #2563eb; text-decoration: none;">Início</a></li>
            <li>/</li>
            <li>Blog</li>
        </ol>
    </nav>
</MainLayout>
