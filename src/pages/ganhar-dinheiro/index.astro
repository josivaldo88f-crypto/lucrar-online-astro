---
import MainLayout from '../../layouts/MainLayout.astro';
import PostCard from '../../components/PostCard.astro';

const posts = await Astro.glob('../**/*.astro');
const categoryPosts = posts
    .filter(post => {
        const title = post.title || post.frontmatter?.title;
        const postCategoria = post.frontmatter?.categoria || post.categoria;
        
        // Deve ter título, URL e a categoria correta
        // E não ser a própria página de índice
        return (
            post.url && 
            title && 
            post.url !== Astro.url.pathname && 
            post.url !== Astro.url.pathname + '/' &&
            postCategoria === "GANHAR DINHEIRO"
        );
    })
    .sort((a, b) => {
        const dateA = new Date(a.date || a.frontmatter?.date || '0').getTime();
        const dateB = new Date(b.date || b.frontmatter?.date || '0').getTime();
        return dateB - dateA;
    });

const categoria = "GANHAR DINHEIRO";
const title = "GANHAR DINHEIRO";
const description = "Confira nossos artigos detalhados sobre como ganhar dinheiro na internet.";
---

<MainLayout title={title} description={description} categoria={categoria} showRelacionados={false}>
    <h1 class="page-title" style="margin-bottom: 2rem; color: #2563eb;">{title}</h1>
    
    <div class="posts-grid">
        {categoryPosts.map(post => {
            const postTitle = post.title || post.frontmatter?.title;
            const postDescription = post.description || post.frontmatter?.description;
            const postImage = post.image || post.frontmatter?.image || '/images/default-post.webp';
            const postDate = post.date || post.frontmatter?.date;
            
            return (
                <PostCard 
                    title={postTitle}
                    description={postDescription}
                    url={post.url}
                    image={postImage}
                    date={postDate}
                />
            );
        })}
    </div>
</MainLayout>