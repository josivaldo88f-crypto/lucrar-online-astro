---
import Relacionados from '../components/Relacionados.astro';

interface Props {
	title?: string;
	description?: string;
	categoria?: string;
	showRelacionados?: boolean;
}

const { 
	title = "Lucrar Online - Seu Guia para Renda Extra na Internet", 
	description = "Aprenda a lucrar online com dicas de apps e sites para ganhar dinheiro e estratégias comprovadas",
	categoria = "geral",
	showRelacionados = true
} = Astro.props;
---

<!doctype html>
<html lang="pt-BR">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="description" content={description} />
		<meta name="keywords" content="lucrar online, renda extra, app para ganhar dinheiro" />
		<title>{title}</title>
		<link rel="stylesheet" href="/styles.css" />
		<style is:global>
			/* Importando estilos globais se necessário */
		</style>
	</head>
	<body>
		<header class="header">
			<div class="container">
				<h1 class="logo"><a href="/" style="text-decoration: none; color: inherit;">Lucrar Online</a></h1>
				<button class="menu-toggle" aria-label="Abrir menu">
					<span class="hamburger"></span>
				</button>
				<nav class="nav">
					<ul class="nav-list">
						<li><a href="/" class="nav-link">Início</a></li>
						<li><a href="/ganhar-dinheiro" class="nav-link">Ganhar Dinheiro</a></li>
						<li><a href="/melhores-apps" class="nav-link">Lista de Melhores Apps</a></li>
						<li><a href="/blog" class="nav-link">Blog</a></li>
						<li><a href="/código-de-convite-do-app-rio-rush-descub" class="nav-link">Código de convite Rio Rush</a></li>
						<li><a href="/app-para-ganhar-dinheiro-assistindo-vídeos" class="nav-link">Ganhe assistindo video</a></li>
					</ul>
				</nav>
			</div>
		</header>

		<main class="main">
			<div class="container">
				<slot />
				{showRelacionados && <Relacionados categoria={categoria} />}
			</div>
		</main>

		<footer class="footer">
			<div class="container">
				<p>&copy; {new Date().getFullYear()} Lucrar Online. Todos os direitos reservados.</p>
			</div>
		</footer>

		<script>
			// Menu Toggle Script
			document.addEventListener('DOMContentLoaded', function() {
				const menuToggle = document.querySelector('.menu-toggle');
				const nav = document.querySelector('.nav');
				
				if (menuToggle && nav) {
					menuToggle.addEventListener('click', function() {
						nav.classList.toggle('nav-open');
						menuToggle.classList.toggle('active');
					});
				}
			});
		</script>
	</body>
</html>
