---
import Relacionados from '../components/Relacionados.astro';

interface Props {
	title?: string;
	description?: string;
	categoria?: string;
	showRelacionados?: boolean;
}

const { 
	title = "Lucrar Online - Seu Guia para Renda Extra na Internet", 
	description = "Aprenda a lucrar online com dicas de apps e sites para ganhar dinheiro e estratégias comprovadas",
	categoria = "geral",
	showRelacionados = true
} = Astro.props;

let canonicalPathname = Astro.url.pathname;
if (canonicalPathname.endsWith('.html')) canonicalPathname = canonicalPathname.slice(0, -5);
if (canonicalPathname !== '/' && !canonicalPathname.endsWith('/')) canonicalPathname += '/';
const canonicalURL = new URL(canonicalPathname, Astro.site ?? 'https://www.lucrar.link/').href;
---

<!doctype html>
<html lang="pt-BR">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="description" content={description} />
		<meta name="keywords" content="lucrar online, renda extra, app para ganhar dinheiro" />
		<title>{title}</title>
		<link rel="canonical" href={canonicalURL} />
		<link rel="stylesheet" href="/styles.css" />
		<style is:global>
			/* Importando estilos globais se necessário */
            .youtube-btn {
                background-color: #FF0000;
                color: white !important;
                padding: 0.5rem 1rem;
                border-radius: 20px;
                font-weight: bold;
                transition: transform 0.2s, background-color 0.2s;
                display: inline-flex;
                align-items: center;
                gap: 0.5rem;
            }
            .youtube-btn:hover {
                background-color: #cc0000;
                transform: scale(1.05);
                text-decoration: none;
            }
		</style>
	</head>
	<body>
		<header class="header">
			<div class="container">
				<h1 class="logo"><a href="/" style="text-decoration: none; color: inherit;">Lucrar Online</a></h1>
				<button class="menu-toggle" aria-label="Abrir menu">
					<span class="hamburger"></span>
				</button>
				<nav class="nav">
					<ul class="nav-list">
						<li><a href="/" class="nav-link">Início</a></li>
						<li><a href="/ganhar-dinheiro/" class="nav-link">Ganhar Dinheiro</a></li>
						<li><a href="/melhores-apps/" class="nav-link">Lista de Melhores Apps</a></li>
						<li><a href="/blog/" class="nav-link">Blog</a></li>
						<li><a href="/código-de-convite-do-app-rio-rush-descub/" class="nav-link">Código de convite Rio Rush</a></li>
						<li><a href="/app-para-ganhar-dinheiro-assistindo-vídeos/" class="nav-link">Ganhe assistindo video</a></li>
						<li>
							<a href="https://www.youtube.com/@LUCRARONLINE" target="_blank" rel="noopener noreferrer" class="nav-link youtube-btn">
								<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="white"><path d="M19.615 3.184c-3.604-.246-11.631-.245-15.23 0-3.897.266-4.356 2.62-4.385 8.816.029 6.185.484 8.549 4.385 8.816 3.6.245 11.626.246 15.23 0 3.897-.266 4.356-2.62 4.385-8.816-.029-6.185-.484-8.549-4.385-8.816zm-10.615 12.816v-8l8 3.993-8 4.007z"/></svg>
								YouTube
							</a>
						</li>
					</ul>
				</nav>
			</div>
		</header>

		<main class="main">
			<div class="container">
				<slot />
				{showRelacionados && <Relacionados categoria={categoria} />}
			</div>
		</main>

		<footer class="footer">
			<div class="container">
				<p>&copy; {new Date().getFullYear()} Lucrar Online. Todos os direitos reservados.</p>
			</div>
		</footer>

		<script>
			document.addEventListener('DOMContentLoaded', function() {
				const pathname = window.location.pathname;
				const shouldAddTrailingSlash = pathname !== '/' && !pathname.endsWith('/') && !pathname.includes('.');
				if (shouldAddTrailingSlash) {
					window.location.replace(pathname + '/' + window.location.search + window.location.hash);
					return;
				}

				const menuToggle = document.querySelector('.menu-toggle');
				const nav = document.querySelector('.nav');
				
				if (menuToggle && nav) {
					menuToggle.addEventListener('click', function() {
						nav.classList.toggle('nav-open');
						menuToggle.classList.toggle('active');
					});
				}
			});
		</script>
	</body>
</html>
